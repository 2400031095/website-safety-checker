{
  "name": "checkfix-app",
  "version": "1.0.0",
  "description": "Fullstack CheckFix project (backend + frontend)",
  "main": "backend/server.js",
  "scripts": {
    "start": "concurrently \"npm run backend\" \"npm run frontend\"",
    "backend": "node backend/server.js",
    "backend-dev": "nodemon backend/server.js",
    "frontend": "cd frontend && npm start",
    "frontend-build": "cd frontend && npm run build",
    "vercel-build": "echo 'No backend build step required'"
  },
  "keywords": [
    "express",
    "backend",
    "api",
    "checkfix",
    "react",
    "frontend"
  ],
  "author": "Your Name",
  "license": "MIT",
  "dependencies": {
    "concurrently": "^8.2.2",
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "express": "^4.22.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.14"
  },
  "engines": {
    "node": ">=18"
  }
}